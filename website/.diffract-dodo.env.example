# Diffract — Dodo Payments LIVE secret for the diffraction.in checkout backend.
#
# Copy this to a file named `.diffract-dodo.env` and place it ONE LEVEL ABOVE
# public_html on the server, i.e. at:
#
#     /home/u878019455/domains/diffraction.in/.diffract-dodo.env
#
# (api/checkout.php reads it from there. Outside public_html = not web-accessible.)
# NEVER commit the real file. NEVER place the real key in git.

DODO_PAYMENTS_API_KEY=PASTE_LIVE_DODO_KEY_HERE

# Control-plane base URL (the auto-provisioner). Used by api/checkout.php +
# api/available.php to check subdomain availability before checkout. Optional —
# if unset, availability checks fail-open (the provisioner still de-dupes names).
CONTROL_PLANE_BASE=https://cp.diffraction.in
