# ─────────────────────────────────────────────────────────────────────────────
# Diffract control plane — configuration.
#
# Copy to `.env` on the CONTROL VPS (never commit the real file). Every value
# below the "OPERATOR MUST SET" line has no safe default — the service refuses
# to start without it (see src/config.mjs).
# ─────────────────────────────────────────────────────────────────────────────

# ── Service ──────────────────────────────────────────────────────────────────
PORT=8787
# Base domain that clients get a subdomain of. Clients become <sub>.CONTROL_DOMAIN.
CONTROL_DOMAIN=diffraction.in
# Public host the control plane answers on (Dodo posts the webhook here:
# https://CONTROL_HOST/webhooks/dodo). Covered by the *.diffraction.in wildcard
# record, so it needs no DNS record of its own. Must not collide with a tenant.
CONTROL_HOST=cp.diffraction.in
# Path to the tenant registry (JSON, source of truth). Keep on a persistent disk.
TENANT_STORE=./data/tenants.json
# Bearer token that protects the internal ops endpoints (/internal/*). Random long string.
ADMIN_API_TOKEN=

# ─────────────────────────────  OPERATOR MUST SET  ───────────────────────────

# ── Dodo Payments ────────────────────────────────────────────────────────────
# Webhook signing secret from the Dodo dashboard (Standard Webhooks; usually
# starts with "whsec_"). Used to verify every incoming webhook.
DODO_WEBHOOK_SECRET=
# OPTIONAL: a Dodo API key, only needed if you want to look up the customer's
# email when a webhook doesn't carry it. Leave blank to rely on webhook payload.
DODO_API_KEY=
DODO_BASE=https://live.dodopayments.com

# ── Hostinger VPS API ────────────────────────────────────────────────────────
# API token from hPanel -> API. Scopes must include VPS management + purchase.
HOSTINGER_API_TOKEN=
HOSTINGER_API_BASE=https://developers.hostinger.com
# Catalog price item id of the VPS plan to buy per client (from your Hostinger
# catalog / `GET /api/billing/v1/catalog`). This is what gets charged to YOUR
# Hostinger billing on every provision.
HOSTINGER_ITEM_ID=
# OS template id — must be a plain Ubuntu 22.04/24.04 (no panel). From
# `GET /api/vps/v1/templates`.
HOSTINGER_TEMPLATE_ID=
# Data center id — from `GET /api/vps/v1/data-centers`.
HOSTINGER_DATACENTER_ID=
# OPTIONAL: payment method id (from `GET /api/billing/v1/payment-methods`).
# Blank => Hostinger uses your account default.
HOSTINGER_PAYMENT_METHOD_ID=
# Enable Hostinger's weekly backups on each client VPS (true/false).
HOSTINGER_ENABLE_BACKUPS=false

# ── Per-client VPS install (baked into the Hostinger post-install script) ─────
# Public IP of THIS control VPS. Each client box ufw-allows ports 3000/9119/8642
# ONLY from this IP, so the ingress can reach it and nobody else can.
INGRESS_PUBLIC_IP=
# Where the client box pulls the installer from (must be publicly reachable).
DIFFRACT_INSTALL_URL=https://raw.githubusercontent.com/riaan-attar/diffract-main/main/install.sh
DIFFRACT_REPO=https://github.com/riaan-attar/diffract-main
DIFFRACT_BRANCH=main
# If the repo is private, a read-only PAT the client box uses to clone it.
DIFFRACT_GITHUB_TOKEN=

# ── Injected shared inference (operator chose: Diffract fronts the key) ───────
# The agent on every client box is auto-deployed with THIS key so chat works out
# of the box. provider is the OpenShell/nemoclaw provider name; model is optional.
INJECT_PROVIDER=nvidia
INJECT_INFERENCE_KEY=
INJECT_MODEL=nvidia/nemotron-3-super-120b-a12b

# ── Central Caddy ingress ────────────────────────────────────────────────────
# Caddy admin API on the control VPS (used to add/remove per-tenant routes).
CADDY_ADMIN=http://127.0.0.1:2019
# Name of the http server block in the Caddyfile we mutate (see deploy/Caddyfile).
CADDY_SERVER=srv0

# ── Welcome email (optional; provisioning still completes if unset) ───────────
# SMTP connection URL, e.g. smtps://user:pass@smtp.hostinger.com:465
SMTP_URL=
SMTP_FROM=Diffract <noreply@diffraction.in>
SUPPORT_EMAIL=support@diffraction.in
