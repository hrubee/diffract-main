# ─────────────────────────────────────────────────────────────────────────────
# Diffract control plane — configuration.
#
# On RAILWAY these are the service's environment Variables (not a committed file).
# Locally you can run: `node --env-file=.env src/server.mjs`.
# Every value below the "OPERATOR MUST SET" line has no safe default — the service
# refuses to start without it (see src/config.mjs). NEVER commit the real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service ──────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — leave unset there. Locally defaults to 8787.
PORT=8787
# Bind address. 0.0.0.0 on Railway (the service is public-facing). Leave default.
BIND_HOST=0.0.0.0
# Base domain that clients get a subdomain of. Clients become <sub>.CONTROL_DOMAIN.
CONTROL_DOMAIN=diffraction.in
# Host the control plane answers on (Dodo posts the webhook to
# https://CONTROL_HOST/webhooks/dodo). Point this (a Railway custom domain) at the
# service. Must not collide with a tenant subdomain.
CONTROL_HOST=cp.diffraction.in
# Public URL where the signup page is served (Dodo return_url + the welcome email
# link). Usually https://CONTROL_HOST, or your apex if you point it at Railway.
PUBLIC_BASE_URL=https://cp.diffraction.in
# Tenant registry (JSON, source of truth). On Railway, mount a Volume at /data so
# it survives redeploys. The Dockerfile already defaults this to /data/tenants.json.
TENANT_STORE=/data/tenants.json
# Bearer token that protects the internal ops endpoints (/internal/*). Long random.
ADMIN_API_TOKEN=

# ─────────────────────────────  OPERATOR MUST SET  ───────────────────────────

# ── Dodo Payments ────────────────────────────────────────────────────────────
# Webhook signing secret from the Dodo dashboard (Standard Webhooks; usually
# starts with "whsec_"). Verifies every incoming webhook.
DODO_WEBHOOK_SECRET=
# API key used by /api/checkout to create the hosted-checkout session. Required
# for the signup page to sell anything (without it checkout returns a 500).
DODO_API_KEY=
# The subscription product the signup page sells (Diffract, ₹2,000/mo LIVE).
DODO_PRODUCT_ID=pdt_0NgoqgyAZmJmzhod4sk1f
DODO_BASE=https://live.dodopayments.com

# ── Hostinger VPS API (per-client box stays on Hostinger) ─────────────────────
# API token from hPanel -> API. Scopes: VPS management + purchase (+ DNS, if you
# use the default Hostinger DNS provider below — one token covers both).
HOSTINGER_API_TOKEN=
HOSTINGER_API_BASE=https://developers.hostinger.com
# Catalog price item id of the VPS plan to buy per client (`GET /api/billing/v1/catalog`).
# Charged to YOUR Hostinger billing on every provision.
HOSTINGER_ITEM_ID=
# OS template id — a plain Ubuntu 22.04/24.04 (`GET /api/vps/v1/templates`).
HOSTINGER_TEMPLATE_ID=
# Data center id (`GET /api/vps/v1/data-centers`).
HOSTINGER_DATACENTER_ID=
# OPTIONAL payment method id (`GET /api/billing/v1/payment-methods`). Blank => default.
HOSTINGER_PAYMENT_METHOD_ID=
# Enable Hostinger weekly backups on each client VPS (true/false).
HOSTINGER_ENABLE_BACKUPS=false

# ── DNS: how <client>.diffraction.in is pointed at each box ───────────────────
# "hostinger" (default) reuses HOSTINGER_API_TOKEN — no nameserver move, domain +
# VPSs in one account. Use "cloudflare" if the zone lives on Cloudflare instead.
DNS_PROVIDER=hostinger
DNS_TTL=300
# OPTIONAL: a separate token for DNS only. Blank => reuse HOSTINGER_API_TOKEN.
HOSTINGER_DNS_TOKEN=
# Only if DNS_PROVIDER=cloudflare:
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4

# ── Per-client VPS install (baked into the Hostinger post-install script) ─────
# Each box runs its OWN HTTPS (Caddy + Let's Encrypt) at <sub>.diffraction.in, so
# there is no central ingress IP to allow — the box opens 80/443 publicly.
DIFFRACT_INSTALL_URL=https://raw.githubusercontent.com/hrubee/diffract-main/main/install.sh
DIFFRACT_REPO=https://github.com/hrubee/diffract-main
DIFFRACT_BRANCH=main
# If the repo is private, a read-only PAT the client box uses to clone it.
DIFFRACT_GITHUB_TOKEN=

# ── Injected shared inference (operator chose: Diffract fronts the key) ───────
# The agent on every client box is auto-deployed with THIS key so chat works out
# of the box. provider is the OpenShell/nemoclaw provider name; model is optional.
INJECT_PROVIDER=nvidia
INJECT_INFERENCE_KEY=
INJECT_MODEL=nvidia/nemotron-3-super-120b-a12b

# ── Welcome email (optional; provisioning still completes if unset) ───────────
# SMTP connection URL, e.g. smtps://user:pass@smtp.hostinger.com:465
SMTP_URL=
SMTP_FROM=Diffract <noreply@diffraction.in>
SUPPORT_EMAIL=support@diffraction.in
