/local.sh
hermes-agent-main.zip

# Operational folders
node_modules/
dist/
build/
.venv/
__pycache__/

# Logs and cache files
*.log
.DS_Store
Thumbs.db

# Local credentials / secrets — never commit
CREDENTIALS.local.md
*.local.md
*.secret
secrets/
